# DealFlow Environment Variables
# Set these in Railway dashboard under Variables

# REQUIRED
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # Claude AI scoring + photo analysis
APIFY_API_KEY=your_apify_api_key_here             # Zillow scraping via Apify

# REQUIRED for email alerts
GMAIL_USER=your_gmail@gmail.com
GMAIL_PASSWORD=your_gmail_app_password           # Gmail App Password (not regular password)
ALERT_EMAIL=your_email@gmail.com                 # Where deal alerts get sent

# AUTO-SET by Railway (add Postgres plugin)
DATABASE_URL=                                    # Leave empty for local SQLite

# OPTIONAL
PORT=8080                                        # Railway sets this automatically
FLASK_DEBUG=0
